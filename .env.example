# Copy to .env and adjust. docker compose reads it automatically.

# vLLM image tag. Minimum for HunyuanOCR is v0.12.0; v0.24.0 is the latest stable (July 2026).
VLLM_TAG=v0.24.0

# Hugging Face repo `docker compose up` downloads into ./models/$MODEL_DIR before
# starting ocr (see download_model.sh). Change MODEL_DIR too if you point this at
# a different repo, otherwise ocr will keep serving whatever's already there.
MODEL_ID=tencent/HunyuanOCR
MODEL_DIR=HunyuanOCR

# Host port for the OpenAI-compatible API.
PORT=6969

# --- VRAM tuning ---------------------------------------------------------------
# Target card is 16 GB, which is BELOW the official 20 GB minimum, so keep these tight
# and validate on the real card. Lower MAX_MODEL_LEN / MAX_NUM_SEQS first if you hit OOM.

# Fraction of GPU memory vLLM may use.
GPU_MEMORY_UTILIZATION=0.6

# Max context = input vision tokens + prompt + output tokens.
MAX_MODEL_LEN=16384

# Max concurrent requests. Each one costs KV-cache memory; lower it on tight VRAM.
MAX_NUM_SEQS=2
